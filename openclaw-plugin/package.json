{
    "name": "@twsxtd/hapi-openclaw",
    "version": "0.1.8",
    "description": "Native OpenClaw plugin that bridges HAPI to the OpenClaw Gateway route surface.",
    "license": "AGPL-3.0-only",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./openclaw.plugin.json": "./openclaw.plugin.json"
    },
    "files": [
        "dist",
        "openclaw.plugin.json",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.ts --outfile dist/index.js --target node",
        "prepack": "bun run build"
    },
    "dependencies": {
        "hono": "^4.11.2",
        "openclaw": "2026.4.11"
    },
    "devDependencies": {
        "@types/node": ">=25",
        "bun-types": "^1.3.5",
        "typescript": "^5"
    },
    "openclaw": {
        "extensions": [
            "./dist/index.js"
        ],
        "compat": {
            "pluginApi": ">=2026.4.11",
            "minGatewayVersion": "2026.4.11"
        },
        "build": {
            "openclawVersion": "2026.4.11",
            "pluginSdkVersion": "2026.4.11"
        }
    }
}
